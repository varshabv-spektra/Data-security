{
  "properties": {
    "displayName": "Purview Data Security Hackathon Sandbox Policy",
    "policyType": "Custom",
    "mode": "All",
    "metadata": {
      "category": "CloudLabs Sandbox",
      "version": "1.0.0"
    },
    "parameters": {
      "allowedLocations": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed locations",
          "description": "Allowed Azure regions for lab supporting resources."
        },
        "defaultValue": [
          "eastus2",
          "centralus"
        ]
      },
      "allowedVmSkus": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed VM SKUs",
          "description": "Lab VM SKUs approved for the sandbox."
        },
        "defaultValue": [
          "Standard_B2s",
          "Standard_B2ms"
        ]
      },
      "allowedStorageSkus": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed storage SKUs",
          "description": "Storage account SKUs permitted in the sandbox."
        },
        "defaultValue": [
          "Standard_LRS"
        ]
      }
    },
    "policyRule": {
      "if": {
        "anyOf": [
          {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Compute/virtualMachines"
              },
              {
                "not": {
                  "field": "Microsoft.Compute/virtualMachines/sku.name",
                  "in": "[parameters('allowedVmSkus')]"
                }
              }
            ]
          },
          {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Storage/storageAccounts"
              },
              {
                "not": {
                  "field": "Microsoft.Storage/storageAccounts/sku.name",
                  "in": "[parameters('allowedStorageSkus')]"
                }
              }
            ]
          },
          {
            "not": {
              "field": "location",
              "in": "[parameters('allowedLocations')]"
            }
          }
        ]
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}